# ============================================
# Full-Stack AI Chatbot — Environment Variables
# ============================================

# --- Backend ---
PORT=3001
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=24h

# --- External n8n Configuration ---
# Use the full URL of your functional n8n instance
N8N_CHAT_WEBHOOK_URL=http://your-n8n-instance:5678/webhook/chat
N8N_INGEST_WEBHOOK_URL=http://your-n8n-instance:5678/webhook/ingest

# --- Security Note ---
# Ensure your external n8n webhooks are protected or use a secure tunnel

# --- Frontend ---
VITE_API_URL=http://localhost:3001/api

# --- Demo User Credentials ---
DEMO_USER_EMAIL=admin@chatbot.com
DEMO_USER_PASSWORD=password123
