# Copy this file to .env and fill in the values for your local environment.
# Do not commit .env to source control.

POSTGRES_USER=root
POSTGRES_PASSWORD=change_me
POSTGRES_DB=n8n

N8N_ENCRYPTION_KEY=your_random_32_char_secret
N8N_USER_MANAGEMENT_JWT_SECRET=your_random_32_char_secret
N8N_DEFAULT_BINARY_DATA_MODE=filesystem

# Optional: use a local OLLAMA instance when needed.
# OLLAMA_HOST=host.docker.internal:11434
