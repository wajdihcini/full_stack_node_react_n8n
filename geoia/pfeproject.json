 matches in the text\n  while ((match = regex.exec(mdContent)) !== null) {\n    if (match[1]) {\n      imageNames.push(match[1]); // match[1] contains just the filename\n    }\n  }\n  \n  // Store the array of extracted filenames into the new field\n  item.json.myNewField = imageNames;\n}\n\nreturn $input.all();\n"},"type":"n8n-nodes-base.code","typeVersion":2,"position":[-64,-64],"id":"6762d1e1-3010-40cb-8481-4550310be8b8","name":"Code in JavaScript"},{"parameters":{"fieldToSplitOut":"myNewField","options":{}},"type":"n8n-nodes-base.splitOut","typeVersion":1,"position":[256,16],"id":"e29e1140-12c5-4323-b93e-e2e8a583fd6d","name":"Split Out"},{"parameters":{"executeOnce":false,"command":"=mv /data/shared/docling-scratch/{{ $json.myNewField }} /data/shared/extracted-images/"},"type":"n8n-nodes-base.executeCommand","typeVersion":1,"position":[464,16],"id":"a4efcc49-90a2-40c8-aab9-78a33e201483","name":"Execute Command"},{"parameters":{"mode":"insert","qdrantCollection":{"__rl":true,"value":"multi-modalrag","mode":"list","cachedResultName":"multi-modalrag"},"options":{}},"type":"@n8n/n8n-nodes-langchain.vectorStoreQdrant","typeVersion":1.3,"position":[144,-544],"id":"6df986cd-1f91-46e5-9992-b66982e3f672","name":"Qdrant Vector Store","credentials":{"qdrantApi":{"id":"sFfERYppMeBnFNeA","name":"Local QdrantApi database"}}},{"parameters":{"model":"nomic-embed-text:latest"},"type":"@n8n/n8n-nodes-langchain.embeddingsOllama","typeVersion":1,"position":[128,-320],"id":"e658a07c-b35d-4eaf-b361-b2c5f6ba49ce","name":"Embeddings Ollama","credentials":{"ollamaApi":{"id":"xHuYe0MDGOs9IpBW","name":"Local Ollama service"}}},{"parameters":{"textSplittingMode":"custom","options":{}},"type":"@n8n/n8n-nodes-langchain.documentDefaultDataLoader","typeVersion":1.1,"position":[416,-400],"id":"bb0659b1-4ee0-46ea-9af8-347bebac195b","name":"Default Data Loader"},{"parameters":{"chunkSize":700,"options":{}},"type":"@n8n/n8n-nodes-langchain.textSplitterRecursiveCharacterTextSplitter","typeVersion":